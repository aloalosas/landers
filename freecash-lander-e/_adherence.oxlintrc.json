{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "ds-preview-runtime.js",
              "ui_kits/freecash-lander-en/**",
              "ui_kits/freecash-lander/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Montserrat|Poppins))/i]",
        "message": "Font not provided by the design system. Available: Inter, Montserrat, Poppins."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|white|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, white, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:logo|step|tint|alert)$/]",
        "message": "<Badge> variant must be one of 'logo' | 'step' | 'tint' | 'alert'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BonusNotification'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|sub|className|key|ref|className|style|children)$/]",
        "message": "<BonusNotification> doesn't accept that prop. Declared props: icon, title, sub, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|arrow|href|disabled|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, arrow, href, disabled, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|gold|apple)$/]",
        "message": "<Button> variant must be one of 'primary' | 'gold' | 'apple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CountdownTimer'] > JSXAttribute > JSXIdentifier[name!=/^(?:seconds|label|className|key|ref|className|style|children)$/]",
        "message": "<CountdownTimer> doesn't accept that prop. Declared props: seconds, label, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|desc|selected|onSelect|className|key|ref|className|style|children)$/]",
        "message": "<OptionCard> doesn't accept that prop. Declared props: title, desc, selected, onSelect, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewStars'] > JSXAttribute > JSXIdentifier[name!=/^(?:rating|text|className|key|ref|className|style|children)$/]",
        "message": "<ReviewStars> doesn't accept that prop. Declared props: rating, text, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|options|className|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: value, onChange, placeholder, options, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|value|label|className|key|ref|className|style|children)$/]",
        "message": "<StatPill> doesn't accept that prop. Declared props: icon, value, label, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:users|cash|bolt|check)$/]",
        "message": "<StatPill> icon must be one of 'users' | 'cash' | 'bolt' | 'check'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Timeline'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|steps|className|key|ref|className|style|children)$/]",
        "message": "<Timeline> doesn't accept that prop. Declared props: label, steps, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
